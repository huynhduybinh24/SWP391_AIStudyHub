	"item": [
		{
			"name": "1. Login (Get JWT Token)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// 1. HTTP Status & Timing Assertions",
							"pm.test(\"TC-01-A | HTTP Status is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"TC-01-B | Response time is fast (<500ms)\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(500);",
							"});",
							"",
							"// 2. Header Assertions",
							"pm.test(\"TC-01-C | Content-Type is application/json\", function () {",
							"    pm.response.to.have.header(\"Content-Type\");",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
							"});",
							"",
							"// 3. Body Data Integrity & Schema Check",
							"pm.test(\"TC-01-D | Login Response Schema & Values\", function () {",
							"    var jsonData = pm.response.json();",
							"    ",
							"    // Verify user object structure",
							"    pm.expect(jsonData).to.have.property('user');",
							"    pm.expect(jsonData.user.id).to.exist;",
							"    pm.expect(jsonData.user.email).to.eql(\"student@lumiedu.com\");",
							"    pm.expect(jsonData.user.role).to.eql(\"user\");",
							"    ",
							"    // Verify tokens",
							"    pm.expect(jsonData).to.have.property('tokens');",
							"    pm.expect(jsonData.tokens.accessToken).to.be.a('string');",
							"    pm.expect(jsonData.tokens.refreshToken).to.be.a('string');",
							"    ",
							"    // Set Global Variables dynamically for subsequent tests",
							"    pm.globals.set(\"accessToken\", jsonData.tokens.accessToken);",
							"    pm.globals.set(\"userId\", jsonData.user.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"student@lumiedu.com\",\n  \"password\": \"123456\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:8080/api/auth/login",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
