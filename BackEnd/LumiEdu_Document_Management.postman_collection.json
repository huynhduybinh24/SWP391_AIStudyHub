							"});",
							"",
							"// 2. Data Structure & Fields Assertions",
							"pm.test(\"TC-02-C | Response format matches API standard\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.eql(true);",
							"    pm.expect(jsonData.message).to.eql(\"Documents retrieved successfully.\");",
							"    pm.expect(jsonData.data).to.be.an('array');",
							"});",
							"",
							"pm.test(\"TC-02-D | Verify objects in list have required attributes\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.data.length > 0) {",
							"        var firstDoc = jsonData.data[0];",
							"        pm.expect(firstDoc).to.have.all.keys(",
							"            'id', 'title', 'description', 'fileName', 'originalFileName', ",
							"            'fileUrl', 'googleDriveFileId', 'storageProvider', 'fileType', ",
							"            'mimeType', 'fileSize', 'subject', 'visibility', 'userId', ",
							"            'ownerName', 'ownerEmail', 'role', 'status', 'tags', ",
							"            'createdAt', 'updatedAt'",
							"        );",
							"        pm.expect(firstDoc.id).to.be.a('number');",
							"        pm.expect(firstDoc.visibility).to.be.oneOf(['PUBLIC', 'PRIVATE', 'SHARED', 'private', 'public', 'shared']);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
